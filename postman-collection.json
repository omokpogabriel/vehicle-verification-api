{
  "info": {
    "name": "Vehicle Verification API",
    "description": "Complete collection for the Vehicle Verification API. Import this file into Postman. Set the `baseUrl` collection variable to your server address before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",         "value": "http://localhost:8002", "type": "string" },
    { "key": "accessToken",     "value": "",                      "type": "string" },
    { "key": "refreshToken",    "value": "",                      "type": "string" },
    { "key": "biometricToken",  "value": "",                      "type": "string" },
    { "key": "username",        "value": "testuser",              "type": "string" },
    { "key": "password",        "value": "password123",           "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "",
                  "pm.test('Response has accessToken', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Response has refreshToken', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('tokenType is Bearer', () => {",
                  "    pm.expect(pm.response.json().tokenType).to.eql('Bearer');",
                  "});",
                  "",
                  "// Auto-save tokens",
                  "const body = pm.response.json();",
                  "if (body.accessToken)  pm.collectionVariables.set('accessToken',  body.accessToken);",
                  "if (body.refreshToken) pm.collectionVariables.set('refreshToken', body.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "ipaddress",         "value": "127.0.0.1" },
              { "key": "location",          "value": "Lagos, Nigeria" },
              { "key": "appInstallationId", "value": "test-device-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"testuser@example.com\",\n  \"phone\": \"08012345678\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"] }
          }
        },
